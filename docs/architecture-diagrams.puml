' 7. ENTITY RELATIONSHIP — Core Card Storage Model
' ══════════════════════════════════════════════════════════
@startuml er-card-model
!theme plain
top to bottom direction
skinparam ranksep 40
skinparam nodesep 30

title Commander Collector — ER Diagram: Core Card Model (v5.0.0)

entity "players" as PLAYERS {
  * id : int
  --
  name : varchar(100)
  user_id : char(36)
  created_at : timestamp
}

entity "decks" as DECKS {
  * id : int
  --
  player_id : int <<FK>>
  name : varchar(100)
  commander : varchar(150) <<deck-native>>
  partner : varchar(150) <<deck-native>>
  colors : varchar(10) <<deck-native>>
  has_w/u/b/r/g : tinyint(1) <<deck-native>>
  created_at : timestamp
}

entity "lists" as LISTS {
  * id : int
  --
  deck_id : int <<FK, optional>>
  name : varchar(255)
  description : text
  user_id : varchar(36)
  created_at : timestamp
  updated_at : timestamp
}

entity "list_cards" as LIST_CARDS {
  * id : int
  --
  list_id : int <<FK>>
  scryfall_id : varchar(64)
  card_name : varchar(255)
  quantity : int
  is_commander : tinyint(1)
  is_proxy : tinyint(1)
  role : varchar(32) <<list-native>>
}

entity "list_history" as LIST_HISTORY {
  * id : int
  --
  list_id : int <<FK>>
  user_id : varchar(36)
  action : varchar(64)
  payload : json
  created_at : timestamp
}

entity "buffer_drafts" as BUFFER_DRAFTS {
  * id : int
  --
  user_id : varchar(36)
  device_id : varchar(128)
  context_type : varchar(32)
  context_ref : varchar(64)
  state : json
  updated_at : timestamp
}

entity "system_state" as SYSTEM_STATE {
  * key : varchar(64)
  --
  value : text
  updated_at : timestamp
}

entity "game_results" as GAME_RESULTS {
  * id : int
  --
  game_id : int <<FK>>
  deck_id : int <<FK>>
  player_id : int <<FK>>
  finish_position : tinyint
  eliminated_turn : int
}

entity "games" as GAMES {
  * id : int
  --
  played_at : date
  winning_turn : int
  game_type : varchar(20)
  notes : text
}

entity "scryfall_card_cache" as SCC {
  * id : int
  --
  scryfall_id : varchar(36)
  name : varchar(255)
  image_uri : text
  back_image_uri : text
  colors : varchar(10)
  color_identity : varchar(10)
  type_line : varchar(255)
  mana_cost : varchar(100)
}

' Relationships
PLAYERS ||--o{ DECKS : "owns"
DECKS ||--o{ LISTS : "has (optional)"
LISTS ||--|{ LIST_CARDS : "contains"
LISTS ||--o{ LIST_HISTORY : "audit trail"
GAMES ||--|{ GAME_RESULTS : "produces"
DECKS ||--o{ GAME_RESULTS : "recorded in"
PLAYERS ||--o{ GAME_RESULTS : "participates"

note right of LISTS
  lists.deck_id is the join from a list
  to its deck. A list may exist standalone
  (no deck_id) — e.g. wishlist, binder.
  A deck may have 0, 1, or many lists.
end note

note right of LIST_CARDS
  list_cards.role is list-native.
  role='commander' and role='partner'
  are the list's own claim, independent
  of decks.commander/partner.
end note

note right of BUFFER_DRAFTS
  Renamed from scan_drafts in v5.0.0.
  Keyed on (user, device, context_type,
  context_ref) for multi-context autosave.
end note

note right of SYSTEM_STATE
  K/V store for app-level state.
  Example key: last_cleanup_at
end note

@enduml

