@startuml sequence-deck-create
!theme plain
title Deck System — Create Deck via Scan

actor User
participant "ScanDeckPage" as Scan
participant "VersionPickerDialog" as VPick
participant "ImageEditorDialog" as IEdit
participant "CardReviewGrid" as Review
participant "ManaSymbol\n(Color Picker)" as Color
participant "DeckBreakdown" as Breakdown
participant "api.ts" as API
participant "scan.php" as ScanAPI
participant "scan-draft.php" as DraftAPI
participant "scryfall-cache.php" as Scryfall
participant "card-prints.php" as Prints
participant "decks.php" as DecksAPI
participant "deck-cards.php" as CardsAPI
database "MySQL" as DB

== Step 0: Capture ==
User -> Scan : Upload photo / take picture
Scan -> Scan : fileToBase64()\nrotate, brightness, contrast

opt Image adjustment needed
  Scan -> IEdit : Open image editor
  User -> IEdit : Crop, rotate, adjust
  IEdit --> Scan : Edited image
end

Scan -> Scan : splitCanvasToTiles()\n3x3 + full = 10 tiles

== Step 1: Review ==
loop Batch of 3 tiles
  Scan -> API : api.scanDeck(base64, mime)
  API -> ScanAPI : POST /scan
  ScanAPI --> API : card names[]
  API --> Scan : ScannedCard[]
  Scan -> Scan : Deduplicate by name
  Scan -> API : api.bulkLookupCards(names)
  API -> Scryfall : POST /scryfall-cache
  Scryfall --> API : ScryfallCachedCard[]
  API --> Scan : Merge scryfall data
end

Scan -> Review : Display card grid for review

opt Cards not found
  Scan -> API : api.findCardCrop(image, name)
  API -> ScanAPI : POST /scan {find_card}
  ScanAPI --> API : crop coordinates
  API --> Scan : crop data URL
end

opt Select specific printing
  User -> Review : Click card version
  Review -> VPick : Open version picker
  VPick -> API : api.getCardPrints(name)
  API -> Prints : GET /card-prints
  Prints --> API : PrintVersion[]
  API --> VPick : Show available printings
  User -> VPick : Select printing
  VPick --> Scan : Updated card with set/art
end

Scan -> API : Auto-save draft (debounced 1.5s)
API -> DraftAPI : POST /scan-draft
DraftAPI -> DB : Persist cross-device draft
User -> Scan : Adjust quantities, toggle commander/proxy
Scan -> Breakdown : Render type/color breakdown
User -> Scan : Click "Save Deck"

== Step 2: Save ==
User -> Color : Select color identity (WUBRG/C)
User -> Scan : Enter deck name, select player
Scan -> API : api.createDeck({player_id, name, commander, colors})
API -> DecksAPI : POST /decks
DecksAPI -> DB : INSERT INTO decks
DB --> DecksAPI : deck.id
DecksAPI --> API : {id}
API --> Scan : deck created

Scan -> API : api.saveDeckCards(deckId, cards[])
API -> CardsAPI : POST /deck-cards
CardsAPI -> DB : DELETE old + INSERT new cards
DB --> CardsAPI : ok
CardsAPI --> API : ok
API --> Scan : saved
Scan -> Scan : router.push(/decks/detail)

@enduml

' ============================================================

@startuml sequence-game-lifecycle
!theme plain
title Game System — Full Game Lifecycle

actor User
participant "GameSetup" as Setup
participant "GameBoard" as Board
participant "PlayerPanel" as Panel
participant "CenterZone" as Center
participant "ControlFocusModal" as Focus
participant "remoteTransforms" as RT
participant "GameEndSummary" as End
participant "GameForm" as Form
participant "api.ts" as API
participant "live-game.php" as Live
participant "game-settings.php" as Settings
participant "games.php" as Games
database "MySQL" as DB

== Setup Phase ==
User -> Setup : Select players, decks, commanders
Setup -> API : api.getPlayers(), api.getDecks()
API --> Setup : Player[], DeckWithPlayer[]
Setup -> API : api.getGameSettings()
API -> Settings : GET /game-settings
Settings --> API : {starting_life, timer_duration, ...}
API --> Setup : User preferences loaded
User -> Setup : Click "Start Game"
Setup -> Setup : Build GameManagerState\n(life=40, poison=0, phase='playing')
Setup -> API : api.createLiveGame(state, seats)
API -> Live : POST /live-game
Live -> DB : INSERT session + seat codes
DB --> Live : session_id, seat codes
Live --> API : {session_id, seats: {bottom: code, ...}}
API --> Setup : sessionCode stored in state

== Playing Phase ==
Board -> Center : Display turn number, active player,\ntimer (default 300s)

loop Each game action
  User -> Panel : Tap life/poison/cmdr/monarch buttons
  Panel -> Board : Bubble up state change
  Board -> RT : applyLifeChange / applyPoisonChange /\napplyCommanderDamage / etc.
  RT --> Board : New GameManagerState
  Board -> API : api.updateLiveGame(code, state)
  API -> Live : PUT /live-game?code=X
  Live -> DB : UPDATE state JSON
end

opt Control/Focus stack interaction
  User -> Board : Trigger stack event
  Board -> Focus : Open ControlFocusModal
  User -> Focus : Resolve stack items
  Focus --> Board : Updated state
end

opt Remote Panel (multi-device)
  Board -> API : api.sendLiveGameEvent(code, event)
  API -> Live : POST /live-game?code=X&action=event
  Live -> DB : Append to events queue (locked txn)

  note right of Live
    Remote panels poll every 500ms
    GET /live-game?code=X&consume=1
    Atomically returns + clears events
  end note
end

opt Player eliminated
  Board -> RT : applyEliminate(state, playerIdx)
  RT --> Board : Mark isEliminated, set eliminatedTurn
  Board -> Board : Check if 1 player remaining
end

== End Phase ==
Board -> Board : Last player standing detected
Board -> Board : 15s countdown timer
Board -> End : Show GameEndSummary

User -> End : Confirm finish positions
End -> End : Build GameManagerPrefill\nStore in localStorage

User -> End : Click "Log Game"
End -> Form : Navigate to /games/new

== Log Phase ==
Form -> Form : Read localStorage prefill\nAuto-populate results
User -> Form : Review/adjust, click Save
Form -> API : api.createGame({played_at, results[]})
API -> Games : POST /games
Games -> DB : INSERT game + game_results (txn)
Games -> DB : Derive winning_turn = MAX(eliminated_turn)
DB --> Games : game.id
Games --> API : {id}
API --> Form : Success
Form -> Form : router.push(/games)

@enduml

' ============================================================

